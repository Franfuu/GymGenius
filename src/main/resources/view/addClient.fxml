<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.developodo.view.FormAuthorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <AnchorPane prefHeight="16.0" prefWidth="200.0">
         <children>
            <Text layoutX="18.0" layoutY="13.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rellene para agregar al cliente" wrappingWidth="200.0">
               <font>
                  <Font size="13.0" />
               </font>
            </Text>
         </children>
      </AnchorPane>
      <TextField fx:id="dni" promptText="Nombre" />
      <TextField fx:id="dni1" promptText="Apellido" />
      <TextField fx:id="name" promptText="DNI" />
      <TextField fx:id="dni3" promptText="Teléfono" />
      <MenuButton mnemonicParsing="false" prefHeight="26.0" prefWidth="77.0" text="Sexo">
        <items>
          <MenuItem mnemonicParsing="false" text="Masculino" />
          <MenuItem mnemonicParsing="false" text="Femenino" />
        </items>
      </MenuButton>
      <Button mnemonicParsing="false" onAction="#closeWindow" prefHeight="26.0" prefWidth="80.0" text="Agregar" />
   </children>
</VBox>
